# バックエンド開発サーバのポート。
PORT=3001

# DB 接続文字列。backend は @icasu/db を import するので DB クライアントが実行時に読む。
# ローカル開発では docker-compose の Postgres を指す。Aurora DSQL と DB_* の全オプションは
# packages/db/.env.example を参照。
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/app_dev

# ===========================================================================
# BFF 認証（@icasu/backend-auth）
# ---------------------------------------------------------------------------
# 以下は @icasu/backend-auth が要求する変数。backend は起動時に
# loadAuthConfigFromEnv() で一括検証し、必須変数が欠けていればブート時に落ちる
# （初回リクエストではなく即座にエラー）。
# 下のローカル既定値は docker-compose の mock-oauth2-server + DynamoDB Local
# （`pnpm local:up`）向け。本番では CDK（apps/iac）が Cognito の値を Lambda の
# 環境変数として注入する。
# ===========================================================================

# --- OIDC プロバイダ（すべて必須。OIDC_SCOPES のみ任意）---------------------
OIDC_ISSUER=http://localhost:8080/default
OIDC_AUTHORIZE_URL=http://localhost:8080/default/authorize
OIDC_TOKEN_URL=http://localhost:8080/default/token
OIDC_JWKS_URL=http://localhost:8080/default/jwks
OIDC_CLIENT_ID=local-client
OIDC_CLIENT_SECRET=local-secret
# 任意（既定: "openid email profile"）。
OIDC_SCOPES=openid email profile

# --- BFF エンドポイント（すべて必須）---------------------------------------
# コールバック URI（プロバイダに登録済みのリダイレクト URI と一致させる）。
# OAuth 遷移は JSON API（/api）と別系統の /auth 配下（Vite が /auth を BFF にプロキシ）。
AUTH_REDIRECT_URI=http://localhost:5001/auth/callback
# ログアウト URL テンプレート。{redirect} は APP_BASE_URL（URL エンコード）に置換される。
# Cognito 形式: https://<domain>/logout?client_id=<id>&logout_uri={redirect}
AUTH_LOGOUT_URL=http://localhost:8080/default/endsession?post_logout_redirect_uri={redirect}
# SPA の URL。ログイン/ログアウト後にここへ着地する。
APP_BASE_URL=http://localhost:5001

# --- セッション Cookie（不透明・署名付き。COOKIE_SECRET のみ必須）----------
# 任意（既定: "sid"）。本番は __Host- プレフィックス付きを推奨。
COOKIE_NAME=sid
# 任意（既定: "true"）。ローカルは http なので false。
COOKIE_SECURE=false
# 必須。本物のシークレットは `openssl rand -hex 32` で生成する。
COOKIE_SECRET=dev-only-change-me-0123456789abcdef0123456789abcdef

# --- DynamoDB セッションストア（SESSION_TABLE_NAME のみ必須）---------------
SESSION_TABLE_NAME=sessions
# 任意。DynamoDB Local のときだけ設定する。本番は未設定（AWS の DynamoDB を使う）。
DYNAMODB_ENDPOINT=http://localhost:8000
# 任意（既定: "ap-northeast-1"）。
AWS_REGION=ap-northeast-1
