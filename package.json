{
  "name": "project-template-2026",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:backend": "pnpm --filter @icasu/backend dev",
    "dev:frontend": "pnpm --filter @icasu/frontend dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "steiger": "pnpm --filter @icasu/frontend run steiger",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "local:up": "docker compose up -d --wait",
    "db:generate": "pnpm --filter @icasu/db db:generate",
    "db:migrate": "pnpm --filter @icasu/db db:migrate",
    "db:push": "pnpm --filter @icasu/db db:push",
    "db:studio": "pnpm --filter @icasu/db db:studio",
    "cdk:synth": "pnpm --filter @icasu/iac run synth",
    "cdk:diff": "pnpm --filter @icasu/iac run diff",
    "cdk:deploy": "pnpm --filter @icasu/iac run deploy",
    "prepare": "husky"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "typescript": "7.0.2"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "oxfmt --no-error-on-unmatched-pattern",
      "oxlint --fix --no-error-on-unmatched-pattern"
    ],
    "*.{json,jsonc,css,md}": [
      "oxfmt --no-error-on-unmatched-pattern"
    ]
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.9.0"
}
