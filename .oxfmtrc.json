{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 100,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": true,
  "trailingComma": "all",
  "insertFinalNewline": true,
  "sortImports": true,
  "sortTailwindcss": true,
  "ignorePatterns": ["**/dist/**", "**/node_modules/**", "**/shared/ui/**", "**/.claude/skills/**"]
}
