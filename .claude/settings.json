{
  "enabledPlugins": {
    "skill-creator@claude-plugins-official": true
  },
  "enabledMcpjsonServers": ["aws-knowledge-mcp-server", "aws-iac-mcp-server"],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/block-no-verify.mjs\""
          }
        ]
      }
    ]
  }
}
