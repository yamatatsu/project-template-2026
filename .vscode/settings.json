{
  // Oxc 拡張（oxlint + oxfmt）を全言語の既定フォーマッタにし、保存時に整形する。
  // CLI（pnpm format / pnpm lint）と挙動を揃え、コミット前の lint-staged と二重に担保する。
  "editor.defaultFormatter": "oxc.oxc-vscode",
  "editor.formatOnSave": true,
  // 保存時に oxlint の自動修正（未使用 import 削除など）を適用する。
  "editor.codeActionsOnSave": {
    "source.fixAll.oxc": "explicit"
  },
  // 言語ごとにも明示しておき、他拡張が既定フォーマッタを奪っても Oxc を使わせる。
  "[typescript]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[javascript]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[json]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[css]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[markdown]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  }
}
