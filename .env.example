# Backend
PORT=3001
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/app_dev

# Aurora DSQL (alternative to DATABASE_URL). When DSQL_ENDPOINT is set, the DB
# client connects to DSQL with short-lived IAM auth tokens instead of a
# password. In Lambda these are injected by the CDK stack; AWS_REGION is set
# automatically by the runtime.
# DSQL_ENDPOINT=<cluster-id>.dsql.ap-northeast-1.on.aws
# DSQL_REGION=ap-northeast-1
# DSQL_USER=admin
# DSQL_DATABASE=postgres

# Frontend — override the API base URL (defaults to the Vite "/api" proxy in dev)
# VITE_API_URL=http://localhost:3001
