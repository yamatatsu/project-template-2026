# @icasu/db クライアントと drizzle-kit ツール（db:migrate / db:push / db:studio）が使う
# データベース接続設定。

# ローカル / コンテナの Postgres（デフォルト — docker-compose.yml に対応）。
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/app_dev

# Aurora DSQL（DATABASE_URL の代替）。DSQL_ENDPOINT を設定すると、DB クライアントは
# パスワードの代わりに短命の IAM 認証トークンで DSQL に接続する。Lambda ではこれらは
# CDK スタックが注入する。AWS_REGION はランタイムが自動で設定する。
# DSQL_ENDPOINT=<cluster-id>.dsql.ap-northeast-1.on.aws
# DSQL_REGION=ap-northeast-1
# DSQL_USER=admin
# DSQL_DATABASE=postgres
