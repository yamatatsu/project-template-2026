# Takumi Guard — registry proxy that blocks known-malicious packages.
# https://shisho.dev/docs/t/guard/quickstart/npm
# Used by npm / pnpm / yarn and read by Bun for compatibility.
registry=https://npm.flatt.tech/

# Authenticated (org) mode — adds install tracking + org breach notifications.
# Issue a tg_org_ token from Shisho Cloud and provide it via the env var below.
# NEVER commit the token itself — keep it in CI secrets / your shell env.
# //npm.flatt.tech/:_authToken=${TAKUMI_GUARD_TOKEN}
